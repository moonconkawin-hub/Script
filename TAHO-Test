--========================
-- LOAD RAYFIELD (SAFE)
--========================
local success, Rayfield = pcall(function()
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not success or not Rayfield then
    warn("Rayfield failed to load")
    return
end

--========================
-- KEY SYSTEM
--========================
local Keys = {
    ["TAHO-123"] = true,
    ["TEST"] = true
}

local function normalize(str)
    return string.upper((str or ""):gsub("%s+", ""))
end

local function CheckKey(k)
    return Keys[normalize(k)] == true
end

--========================
-- WINDOW (CLEAN UI)
--========================
local Window = Rayfield:CreateWindow({
    Name = "Taho Hub",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "Keyless Access",
    ConfigurationSaving = { Enabled = false }
})

local KeyTab = Window:CreateTab("Key")
local Unlocked = false

--========================
-- SAFE RUN FUNCTION
--========================
local function runScript(url)
    local ok, err = pcall(function()
        loadstring(game:HttpGet(url, true))()
    end)

    if not ok then
        Rayfield:Notify({
            Title = "Error",
            Content = "Failed to load script",
            Duration = 3
        })
        warn(err)
    end
end

--========================
-- KEY INPUT
--========================
KeyTab:CreateInput({
    Name = "Enter Key (Optional)",
    PlaceholderText = "key",

    Callback = function(Text)
        if Unlocked then return end

        local input = normalize(Text)

        -- keyless mode
        if input == "" then
            Unlocked = true

        -- valid key
        elseif CheckKey(input) then
            Unlocked = true
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "Invalid Key",
                Duration = 3
            })
            return
        end

        Rayfield:Notify({
            Title = "Success",
            Content = "Access Granted",
            Duration = 3
        })

        --========================
        -- MAIN TAB
        --========================
        local MainTab = Window:CreateTab("Main")

        MainTab:CreateParagraph({
            Title = "Unlocked",
            Content = "Ready to use"
        })

        MainTab:CreateButton({
            Name = "Combat Warriors",
            Callback = function()
                runScript("https://lumin-hub.lol/cw.lua")
            end
        })

        MainTab:CreateButton({
            Name = "Taho GUI",
            Callback = function()
                runScript("https://raw.githubusercontent.com/moonconkawin-hub/Script/refs/heads/main/Taho%20SS%20GUI")
            end
        })

        MainTab:CreateButton({
            Name = "Zombie Area",
            Callback = function()
                runScript("https://raw.githubusercontent.com/caomod2077/Script/main/Foxname_SZA.lua")
            end
        })

        --========================
        -- DISCORD TAB
        --========================
        local DiscordTab = Window:CreateTab("Discord")

        DiscordTab:CreateButton({
            Name = "Copy Discord",
            Callback = function()
                setclipboard("https://discord.gg/XBcEU5CPGp")

                Rayfield:Notify({
                    Title = "Discord",
                    Content = "Copied!",
                    Duration = 3
                })
            end
        })
    end
})
