import json
import secrets
import time
import requests

# 🚨 ตั้งค่าข้อมูล GitHub ของคุณตรงนี้
GITHUB_TOKEN = "https://raw.githubusercontent.com/moonconkawin-hub/Script/refs/heads/main/U"
REPO_OWNER = "moonconkawin-hub"
REPO_NAME = "Script"
FILE_PATH = "KeyData.json"

def generate_key(days_valid, target_hwid=""):
    """ ฟังก์ชันสุ่มคีย์และคำนวณวันหมดอายุ """
    # สุ่มรหัสต่อท้ายความยาว 8 ตัวอักษร
    random_part = secrets.token_hex(4).upper()
    # เปลี่ยนคำขึ้นต้นเป็น MoonconHub ตามสั่ง
    key = f"MoonconHub-{random_part[:4]}-{random_part[4:]}"
    
    # คำนวณเวลาหมดอายุ (วินาที)
    expires_at = int(time.time()) + (days_valid * 86400)
    
    key_info = {
        "HWID": target_hwid,      # ใส่ HWID ของลูกค้าที่ซื้อไป (ถ้ายังไม่มีให้ใส่เป็น "")
        "ExpiresAt": expires_at,  # เวลาหมดอายุ
        "Comment": f"Valid for {days_valid} days"
    }
    return key, key_info

def update_github_database(new_key, key_info):
    """ ฟังก์ชันส่งข้อมูลคีย์ตัวใหม่ขึ้นไปอัปเดตบน GitHub """
    url = f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}/contents/{FILE_PATH}"
    headers = {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": "application/vnd.github.v3+json"
    }
    
    # 1. ดึงข้อมูลไฟล์เก่าลงมาก่อน
    response = requests.get(url, headers=headers)
    sha = ""
    current_data = {}
    
    if response.status_code == 200:
        file_content = response.json()
        sha = file_content['sha']
        import base64
        decoded_content = base64.b64decode(file_content['content']).decode('utf-8')
        if decoded_content.strip():
            current_data = json.loads(decoded_content)
            
    # 2. เพิ่มคีย์ใหม่เข้าไปในระบบ
    current_data[new_key] = key_info
    
    # 3. ส่งกลับขึ้น GitHub
    updated_json_str = json.dumps(current_data, indent=4)
    import base64
    encoded_content = base64.b64encode(updated_json_str.encode('utf-8')).decode('utf-8')
    
    payload = {
        "message": f"Added new key: {new_key}",
        "content": encoded_content,
        "sha": sha
    }
    
    put_response = requests.put(url, headers=headers, json=payload)
    if put_response.status_code in [200, 201]:
        print(f"\n[สำเร็จ] สร้างคีย์ใหม่เรียบร้อย!")
        print(f"🔑 คีย์ของคุณคือ: {new_key}")
        print(f"🔒 ล็อก HWID สำหรับ: {'ทุกคน (เปิดโล่งรอผูก)' if key_info['HWID'] == '' else key_info['HWID']}")
        print(f"⏳ หมดอายุในอีก: {key_info['Comment']}")
    else:
        print("[ล้มเหลว] ไม่สามารถอัปเดตไฟล์บน GitHub ได้ ตรวจสอบ Token ของคุณ")

if __name__ == "__main__":
    print("=== ระบบสร้างคีย์ MoonconHub ===")
    days = int(input("ต้องการให้คีย์นี้ใช้งานได้กี่วัน?: "))
    hwid_input = input("ใส่ HWID ลูกค้าที่จะล็อก (หากยังไม่มีให้กด Enter ข้าม): ").strip()
    
    generated_key, info = generate_key(days, hwid_input)
    update_github_database(generated_key, info)
