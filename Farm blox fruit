getgenv().AutoFarmLevel = true

local Player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local VirtualUser = game:GetService("VirtualUser")
local flySpeed = 100

-- Anti-AFK
Player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- ฟังก์ชันเช็คเลเวลเพื่อดึงชื่อมอนสเตอร์, ชื่อเควส, และ ID ของเควส
local function GetQuestAndMob()
    local myLevel = Player.Data.Level.Value
    
    if myLevel >= 1 and myLevel < 10 then
        return "Bandit [Lv. 5]", "BanditQuest1", 1
    elseif myLevel >= 10 and myLevel < 15 then
        return "Monkey [Lv. 14]", "JungleQuest", 1
    elseif myLevel >= 15 and myLevel < 30 then
        return "Gorilla [Lv. 20]", "JungleQuest", 2
    elseif myLevel >= 30 and myLevel < 60 then
        return "Pirate [Lv. 35]", "BuggyQuest1", 1
    elseif myLevel >= 60 and myLevel < 90 then
        return "Brute [Lv. 45]", "BuggyQuest1", 2
    elseif myLevel >= 90 and myLevel < 700 then
        return "Snow Bandit [Lv. 90]", "SnowQuest", 1
    elseif myLevel >= 700 then
        return "Raider [Lv. 700]", "Area1Quest", 1
    else
        return "Bandit [Lv. 5]", "BanditQuest1", 1
    end
end

local function CheckAndTween(targetCFrame)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local distance = (hrp.Position - targetCFrame.p).Magnitude
    if distance > 15 then
        local duration = distance / flySpeed
        local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = targetCFrame
    end
end

task.spawn(function()
    while getgenv().AutoFarmLevel do
        task.wait(0.1)
        pcall(function()
            local targetMon, questName, questId = GetQuestAndMob()
            
            -- ระบบตรวจสอบและรับเควสอัตโนมัติถ้ายังไม่มีเควส
            if not Player.PlayerGui.Main.Quest.Visible then
                -- ส่งคำสั่งไปที่ Server เพื่อรับเควสทันทีโดยไม่ต้องเดินไปคุยกับ NPC
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", questName, questId)
                task.wait(0.5)
            end
            
            local mobFound = false
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v.Name == targetMon and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                    mobFound = true
                    
                    if Player.Character:FindFirstChild("HumanoidRootPart") then
                        Player.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                    end
                    
                    -- บินไปล็อกตำแหน่งนิ่งๆ บนหัวมอนสเตอร์ (ระยะปลอดภัย 7 ฟุต)
                    local aboveMobPosition = v.HumanoidRootPart.CFrame * CFrame.new(0, 7, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                    CheckAndTween(aboveMobPosition)
                    break
                end
            end
            
            -- หากมอนสเตอร์ยังไม่เกิด ให้บินไปสแตนด์บายที่จุดเกิดของมอนสเตอร์ตัวนั้น
            if not mobFound then
                for _, v in pairs(game.Workspace._WorldOrigin.EnemySpawns:GetChildren()) do
                    if v.Name == targetMon then
                        CheckAndTween(v.CFrame + Vector3.new(0, 15, 0))
                        break
                    end
                end
            end
        end)
    end
end)
