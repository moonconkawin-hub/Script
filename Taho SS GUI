-- Button Open Website
Btn.MouseButton1Click:Connect(function()
    Btn.Text = "Opening..."

    local success = pcall(function()
        GuiService:OpenBrowserWindow(DISCORD_LINK)
    end)

    if success then
        Btn.Text = "✓ Opened!"
    else
        if setclipboard then
            setclipboard(DISCORD_LINK)
            Btn.Text = "✓ Link Copied!"
        else
            Btn.Text = "Open manually"
        end
    end

    task.wait(2)
    Btn.Text = "🔗 Join Discord"
end)

-- Rainbow Animation
RunService.RenderStepped:Connect(function()
    RainbowGradient.Rotation += 0.5
    BorderGradient.Rotation += 1
    BtnGradient.Rotation += 1
    BtnStrokeGradient.Rotation += 1
    TahoGradient.Rotation += 1
end)

